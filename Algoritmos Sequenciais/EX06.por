programa {
  funcao inicio() {
    real pesoPrato, resultado

    // Entrada
    escreva("informe o peso do prato: ")
    leia(pesoPrato)

    // Processamento (resultado = peso do prato * 68)

    resultado = pesoPrato * 68

    // Saída
    
    escreva("\no valor total a pagar: R$ ", resultado, " reais")
  }
}