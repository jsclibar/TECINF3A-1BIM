programa {
    
    funcao inicio() {
        real raio, area

        // Entrada
        
        escreva("Digite o raio da pizza: ")
        leia(raio)

        // Processamento
        
        area = 3.14 * raio * raio

        // Saída
        
        escreva("A área da pizza é: ", area)
    }
}
