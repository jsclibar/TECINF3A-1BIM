programa {
  funcao inicio() {

    inteiro n, quant

    escreva("Digite a quantidade de entradas que deseja: ")
    leia(quant)

    para (inteiro i=1; i<=quant; i++){ // Estrutura de repetição começa em i = 1 e é executada enquanto i <= a quantidade de entradas desejadas; i é incrementado de 1 em 1
      escreva("Digite um número qualquer: ")
      leia(n)
    }   
  }
}